# Homepage Environment Variables

# Home Assistant Integration (Optional)
HASS_TOKEN=your_home_assistant_token_here
HASS_URL=https://ha.robinsuter.com

# Traefik (Optional)
TRAEFIK_HOST=traefik.robinsuter.com
TRAEFIK_USER=admin
TRAEFIK_PASS=secure_password

# Proxmox (Optional)
PROXMOX_HOST=proxmox.robinsuter.com
PROXMOX_PASSWORD=proxmox_password

# Synology (Optional)
SYNOLOGY_USER=admin
SYNOLOGY_PASS=synology_password

# Plex (Optional)
PLEX_TOKEN=plex_api_token

# Container Timezone
TZ=UTC

# User/Group IDs for volume permissions
PUID=1000
PGID=1000
